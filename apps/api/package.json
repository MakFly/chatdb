{
  "name": "@chat-assistant/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "test": "bun test",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "db:reset": "bun run src/db/reset.ts && drizzle-kit migrate && bun run src/db/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/mistral": "^3.0.21",
    "@ai-sdk/openai": "^3.0.37",
    "@chat-assistant/shared": "workspace:*",
    "@hono/zod-validator": "^0.5.0",
    "ai": "^6.0.105",
    "better-auth": "^1.2.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.7.0",
    "ioredis": "^5.10.0",
    "mysql2": "^3.18.2",
    "ollama-ai-provider": "^1.2.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.9",
    "@types/node": "^22",
    "drizzle-kit": "^0.30.0",
    "typescript": "5.7.3"
  }
